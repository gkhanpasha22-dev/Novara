---
// FAQ: native <details> accordion (no JS needed). Also emits FAQPage schema.
const faqs = [
  { q: 'Сколько стоит проект?', a: 'Стоимость зависит от объёма и сроков. Небольшой лендинг — от 250 000 ₽, продуктовые проекты считаем индивидуально после брифа. Пришлите задачу — вернёмся со сметой за 2–3 дня.' },
  { q: 'Какие сроки?', a: 'Лендинг — 3–4 недели, полноценный сайт или продукт — от 2 месяцев. Точный план даём после этапа исследования.' },
  { q: 'На каком стеке вы работаете?', a: 'Подбираем стек под задачу: от статических сайтов и Astro/Next.js до headless-CMS. Всегда закладываем скорость, SEO и возможность масштабирования.' },
  { q: 'Поддерживаете проект после запуска?', a: 'Да. Предлагаем поддержку и развитие: обновления, A/B-тесты, аналитику и новые фичи по подписке или почасово.' },
  { q: 'Можно ли масштабировать лендинг до корпоративного сайта?', a: 'Именно так мы и проектируем. Архитектура и вёрстка готовы к росту: блог, вакансии, каталог услуг и интеграция с CMS добавляются без переписывания с нуля.' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---
<section class="faq section" id="faq" aria-labelledby="faq-title">
  <div class="container faq__inner">
    <header class="section__head reveal" data-reveal>
      <p class="eyebrow">FAQ</p>
      <h2 class="section__title" id="faq-title">Частые вопросы</h2>
    </header>

    <div class="faq__list reveal" data-reveal>
      {faqs.map((f) => (
        <details class="faq__item">
          <summary>{f.q}</summary>
          <div class="faq__answer"><p>{f.a}</p></div>
        </details>
      ))}
    </div>
  </div>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</section>
